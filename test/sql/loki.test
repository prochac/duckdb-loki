# name: test/sql/loki.test
# description: test loki extension
# group: [sql]

# Before the extension is loaded, its table functions do not exist.
statement error
SELECT * FROM loki_scan('{job="x"}', endpoint := 'http://localhost:3100');
----
loki_scan

# Require statement will ensure this test is run with this extension loaded
require loki

# Both table functions are registered.
query I
SELECT count(*) FROM duckdb_functions() WHERE function_name IN ('loki_scan', 'loki') AND function_type = 'table';
----
2

# It exposes the base output schema (timestamp, line, labels, structured_metadata). Binding
# does not touch the network, so this is safe without a live Loki.
query II
SELECT column_name, column_type
FROM (DESCRIBE SELECT * FROM loki_scan('{job="x"}', endpoint := 'http://localhost:3100'));
----
timestamp	TIMESTAMP_NS
line	VARCHAR
labels	MAP(VARCHAR, VARCHAR)
structured_metadata	MAP(VARCHAR, VARCHAR)

# v0.3: `labels := [...]` promotes each named label to a top-level VARCHAR column, inserted
# between `line` and the `labels` MAP, in declared order (DESIGN.md §3.2).
query II
SELECT column_name, column_type
FROM (DESCRIBE SELECT * FROM loki_scan('{job="x"}', endpoint := 'http://localhost:3100', labels := ['job', 'pod']));
----
timestamp	TIMESTAMP_NS
line	VARCHAR
job	VARCHAR
pod	VARCHAR
labels	MAP(VARCHAR, VARCHAR)
structured_metadata	MAP(VARCHAR, VARCHAR)

# --- v0.4: the pushdown-driven loki() table function (DESIGN.md §3.2 / §4) ---

# loki() exposes the same schema as loki_scan; `selector` is the base stream selector and
# `labels := [...]` promotes label columns (which is what makes their WHERE predicates pushable).
query II
SELECT column_name, column_type
FROM (DESCRIBE SELECT * FROM loki(selector := '{job="x"}', endpoint := 'http://localhost:3100', labels := ['level']));
----
timestamp	TIMESTAMP_NS
line	VARCHAR
level	VARCHAR
labels	MAP(VARCHAR, VARCHAR)
structured_metadata	MAP(VARCHAR, VARCHAR)

# The mandatory-selector rule (§4.3): with no selector and no WHERE to synthesize one, the scan
# refuses to issue an unbounded query. Raised at scan start, before any network call.
statement error
SELECT * FROM loki(endpoint := 'http://localhost:3100');
----
stream selector is required

# loki() shares loki_scan's connection resolution: no endpoint and no secret is an error. This
# runs before any `loki` secret is created below, so nothing supplies the endpoint.
statement error
SELECT * FROM loki(selector := '{job="x"}');
----
requires an endpoint

# With no endpoint and no secret, binding fails with a clear message (v0.2).
statement error
SELECT * FROM loki_scan('{job="x"}');
----
requires an endpoint

# a query argument is mandatory
statement error
SELECT * FROM loki_scan(endpoint := 'http://localhost:3100');
----

# limit must be positive ("limit" is a reserved word, so it must be quoted)
statement error
SELECT * FROM loki_scan('{job="x"}', endpoint := 'http://localhost:3100', "limit" := 0);
----
must be a positive integer

# direction must be 'backward' or 'forward'
statement error
SELECT * FROM loki_scan('{job="x"}', endpoint := 'http://localhost:3100', direction := 'sideways');
----
must be 'backward' or 'forward'

# INTERVAL time bounds are accepted (offset from now, computed in C++ — no ICU needed).
# Binding does not touch the network, so DESCRIBE is safe.
query I
SELECT count(*) FROM (DESCRIBE SELECT * FROM loki_scan('{job="x"}', endpoint := 'http://localhost:3100', start := -INTERVAL 2 HOUR));
----
4

# Month/year intervals are calendar-dependent and rejected with a helpful message.
statement error
SELECT * FROM loki_scan('{job="x"}', endpoint := 'http://localhost:3100', start := INTERVAL 1 MONTH);
----
calendar-dependent

# --- v0.2 secrets (DESIGN.md §3.1) ---

# A `loki` secret persists endpoint + auth; the table function resolves it by name.
statement ok
CREATE SECRET my_loki (
    TYPE loki,
    ENDPOINT 'http://localhost:3100',
    TOKEN 'glc_secret',
    TENANT '42'
);

# Endpoint comes from the secret, so none is needed inline; schema is unchanged.
query II
SELECT column_name, column_type
FROM (DESCRIBE SELECT * FROM loki_scan('{job="x"}', secret := 'my_loki'));
----
timestamp	TIMESTAMP_NS
line	VARCHAR
labels	MAP(VARCHAR, VARCHAR)
structured_metadata	MAP(VARCHAR, VARCHAR)

# Referencing a secret that does not exist errors clearly.
statement error
SELECT * FROM loki_scan('{job="x"}', secret := 'does_not_exist');
----
no secret named 'does_not_exist'

# A default secret named 'loki' is picked up without an explicit secret := reference.
statement ok
CREATE SECRET loki (TYPE loki, ENDPOINT 'http://localhost:3100');

query I
SELECT count(*) FROM (DESCRIBE SELECT * FROM loki_scan('{job="x"}'));
----
4
